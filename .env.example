# --- IQCDL Platform environment variables ---

# Secret used to sign session JWTs. Generate a strong random value in production.
# e.g. `openssl rand -base64 32`
AUTH_SECRET=change-me-to-a-long-random-string

# Optional: enables the LIVE Claude-powered AI assistant.
# When unset, the platform automatically falls back to the built-in
# rule-based "Quantum Guide" assistant (no key required).
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by the assistant.
ANTHROPIC_MODEL=claude-sonnet-4-6
