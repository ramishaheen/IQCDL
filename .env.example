# --- IQCDL Platform environment variables ---

# Secret used to sign session JWTs. Generate a strong random value in production.
# e.g. `openssl rand -base64 32`
AUTH_SECRET=change-me-to-a-long-random-string

# Optional: enables the LIVE Claude-powered AI assistant.
# When unset, the platform automatically falls back to the built-in
# rule-based "Quantum Guide" assistant (no key required).
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by the assistant.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: DeepSeek as an automatic fallback used when Claude is unavailable
# (no Anthropic key, rate-limited, or erroring). OpenAI-compatible API.
# Get a key at https://platform.deepseek.com/api_keys.
DEEPSEEK_API_KEY=
# Optional: override the DeepSeek model (default: deepseek-chat).
DEEPSEEK_MODEL=deepseek-chat

# Optional: shared portal persistence via Upstash Redis (HTTP, serverless-safe).
# When BOTH are set, the portal (centers, students, exams, certificates, …)
# is stored server-side and shared across devices/users. When unset, the
# portal falls back to per-instance memory + per-browser localStorage.
# Create a free database at https://console.upstash.com and copy the
# "REST" URL and token here (and into the Vercel project's env vars).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: real email sending for the admin "Email students" action via Resend.
# Without RESEND_API_KEY the action is logged only (demo fallback).
# Get a key at https://resend.com. With no verified domain, Resend test mode
# only delivers to your own account email and sends from onboarding@resend.dev.
RESEND_API_KEY=
# Verified sender once you've added a domain in Resend, e.g. "IQCDL <noreply@iqcdl.org>"
RESEND_FROM=

# Optional: $19 Community membership payment via Stripe Checkout.
# When set, "Enroll" opens a real Stripe Checkout session; without it the
# enrollment runs in demo mode (grants membership without charging).
# Get a key at https://dashboard.stripe.com/apikeys (use a test key for testing).
STRIPE_SECRET_KEY=

# Where the admin notification + marketing email destination defaults to.
ADMIN_EMAIL=admin@iqcdl.org

# Public site URL — used as the base for marketing-email links and the
# unsubscribe URL. Defaults to https://iqcdl.org.
NEXT_PUBLIC_SITE_URL=https://iqcdl.org

# Secret that protects the daily marketing-drip and award-outreach crons
# (Vercel sends `Authorization: Bearer <CRON_SECRET>` automatically).
# Generate with `openssl rand -hex 32`.
CRON_SECRET=

# Domain used in the `Reply-To: reply+<targetId>@<domain>` address on award
# outreach emails. Defaults to iqcdl.org. Set this to whatever domain you've
# configured to receive inbound mail and forward to /api/outreach/inbound.
OUTREACH_REPLY_DOMAIN=iqcdl.org

# Optional: shared secret for /api/outreach/inbound (the inbound parser
# includes ?secret=... in its webhook URL). Highly recommended in production.
INBOUND_SECRET=

# Optional: shared secret for /api/webhooks/resend (Resend can include
# ?secret=... in the webhook URL).
RESEND_WEBHOOK_SECRET=
